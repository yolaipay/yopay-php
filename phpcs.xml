<?xml version="1.0"?>
<ruleset name="YoPay PHP SDK">
    <description>PSR-12 checks for the YoPay PHP SDK.</description>
    <rule ref="PSR12"/>
    <file>src</file>
    <file>tests</file>
    <file>examples</file>
    <exclude-pattern>vendor/*</exclude-pattern>
    <rule ref="PSR1.Files.SideEffects">
        <exclude-pattern>examples/notify_server.php</exclude-pattern>
    </rule>
</ruleset>
